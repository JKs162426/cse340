<%- include('partials/header') %>
<main>
  <h1><%= title %></h1>

  <p>Here are a few of our partner organizations:</p>
  <ul>
    <% organizations.forEach(organization => { %>
      <li>
        <img src="/images/<%= organization.logo_filename %>" alt="<%= organization.name %> logo">
        <strong>
          <a href="/organization/<%= organization.organization_id %>"><%= organization.name %></a>
        </strong>: <%= organization.contact_email %>
        <p>
          <a href="/edit-organization/<%= organization.organization_id %>">Edit Organization</a>
        </p>
      </li>
    <% }); %>
  </ul>

  <p><a href="/new-organization">Add a new organization</a></p>
</main>

<%- include('partials/footer') %>