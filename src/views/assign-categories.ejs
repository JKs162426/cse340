<%- include('partials/header') %>

<main>
  <div class="form-container">
    <h1><%= title %></h1>

    <p>Project: <strong><%= projectDetails.title %></strong></p>

    <form action="/assign-categories/<%= projectId %>" method="POST">
      <% categories.forEach(category => { %>
        <div class="form-group">
          <label>
            <input
              type="checkbox"
              name="categories"
              value="<%= category.category_id %>"
              <%= assignedCategories.some(
                    assigned => assigned.category_id === category.category_id
                  ) ? 'checked' : '' %>
            >
            <%= category.name %>
          </label>
        </div>
      <% }) %>

      <div class="form-actions">
        <button type="submit">Save Category Assignments</button>
        <a class="button-link" href="/projects/<%= projectId %>">Cancel</a>
      </div>
    </form>
  </div>
</main>

<%- include('partials/footer') %>